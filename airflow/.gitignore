# ===============================
# FinSight AI - .gitignore
# ===============================

# -----------------
# Secrets & Credentials (NEVER commit these!)
# -----------------
.env
*.env
.env.*
*.pem
*.key
credentials.json
secrets.json
**/secrets/
**/.aws/

# -----------------
# Terraform
# -----------------
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl
*.tfvars
!example.tfvars
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -----------------
# Python
# -----------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
ENV/
env/
.python-version

# -----------------
# Lambda Layers & Packages
# -----------------
lambda_layers/
*.zip
package/
python/

# -----------------
# Airflow
# -----------------
airflow/logs/
airflow/*.log
airflow/airflow.db
airflow/airflow.cfg
airflow/webserver_config.py
airflow/standalone_admin_password.txt

# -----------------
# IDE & Editors
# -----------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# -----------------
# OS Files
# -----------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------
# Logs
# -----------------
*.log
logs/
log/

# -----------------
# Temporary Files
# -----------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------
# Jupyter Notebooks
# -----------------
.ipynb_checkpoints/
*.ipynb

# -----------------
# Test & Coverage
# -----------------
.coverage
htmlcov/
.pytest_cache/
.tox/
nosetests.xml
coverage.xml
